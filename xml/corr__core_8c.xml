      <memberdef kind="function" id="corr__core_8c_1a013a916fa4278c454f5ec1263f408a56" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void corr_set_ref</definition>
        <argsstring>(corr_state_t *state, const float complex *ref)</argsstring>
        <name>corr_set_ref</name>
        <param>
          <type><ref refid="structcorr__state__t" kindref="compound">corr_state_t</ref> *</type>
          <declname>state</declname>
        </param>
        <param>
          <type>const float complex *</type>
          <declname>ref</declname>
        </param>
        <briefdescription>
<para>Replace the reference signal and recompute conj(FFT(ref)). </para>
        </briefdescription>
        <detaileddescription>
<para>Also resets the accumulator and counter (as if <ref refid="corr__core_8h_1a718b28d1ce95cdb7ff020adef0249c9b" kindref="member">corr_reset()</ref> were called). Useful when the reference must change between dwells without tearing down the FFT plans.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>state</parametername>
</parameternamelist>
<parameterdescription>
<para>Must be non-NULL. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>ref</parametername>
</parameternamelist>
<parameterdescription>
<para>New reference signal of length state-&gt;n. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
