<codeline><highlight class="normal"></highlight><highlight class="keywordtype">float</highlight><highlight class="normal"><sp/>complex<sp/>out[4096];</highlight></codeline>
<codeline><highlight class="normal"><ref refid="fir__core_8h_1a4f66044cb44e847e60d004b26b3480de" kindref="member">fir_execute</ref>(fir,<sp/>signal,<sp/>4096,<sp/>out);</highlight></codeline>
<codeline><highlight class="normal"><ref refid="fir__core_8h_1a538f6e18e6d64d3bdaf51a6d6eec6a24" kindref="member">fir_destroy</ref>(fir);</highlight></codeline>
</programlisting> </para>
