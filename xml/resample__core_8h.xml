        <type>void</type>
        <definition>void ciccompmf</definition>
        <argsstring>(double *out, uint32_t N, uint32_t R, uint32_t M)</argsstring>
        <name>ciccompmf</name>
        <param>
          <type>double *</type>
          <declname>out</declname>
        </param>
        <param>
          <type>uint32_t</type>
          <declname>N</declname>
