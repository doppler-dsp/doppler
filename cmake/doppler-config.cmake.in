@PACKAGE_INIT@

# The static library's interface links Threads::Threads (PUBLIC), so resolve it
# before loading the targets that reference it.
include(CMakeFindDependencyMacro)
find_dependency(Threads)

include("${CMAKE_CURRENT_LIST_DIR}/doppler-targets.cmake")

# Link targets provided to consumers (both relocatable, generated by the export
# above — no hand-rolled paths):
#
#   doppler::doppler         shared (libdoppler.so) — links -ldoppler.
#   doppler::doppler-static  the self-contained static archive (the vendored
#                            zmq is folded in), so it links with only the C/C++
#                            runtime — no external zmq.

check_required_components(doppler)
