<codeline lineno="1"><highlight class="normal"></highlight></codeline>
<codeline lineno="20"><highlight class="normal"></highlight><highlight class="preprocessor">#ifndef<sp/>RESAMPLER_CORE_H</highlight><highlight class="normal"></highlight></codeline>
