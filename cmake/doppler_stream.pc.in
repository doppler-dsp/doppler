# Relocatable, like doppler.pc: derive the prefix from this file's own
# location so an extracted release tarball works wherever it lands.
prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${exec_prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: doppler_stream
Description: doppler NATS stream component (dp_pub_*/dp_sub_* wire layer)
Version: @PROJECT_VERSION@
# Requires pulls in the core's flags, so one name gives the whole link
# line: `pkg-config --cflags --libs doppler_stream`. The vendored nats.c
# is statically embedded in both library forms — no external NATS client
# library at build or run time.
Requires: doppler
Libs: -L${libdir} -ldoppler_stream
Libs.private: -lpthread -lm
Cflags: -I${includedir}
