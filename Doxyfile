PROJECT_NAME           = "doppler"
INPUT                  = native/inc native/src
FILE_PATTERNS          = *.h *.hpp *.c *.cpp
RECURSIVE              = YES

EXCLUDE_PATTERNS       = */pocketfft* \
                         */signal_stream.h \
                         */pyex_common.h \
                         *_ext.c

GENERATE_XML           = YES
XML_OUTPUT             = xml

GENERATE_HTML          = YES
HTML_OUTPUT            = html

GENERATE_LATEX         = NO


EXTRACT_ALL            = YES
OPTIMIZE_OUTPUT_FOR_C  = YES
SORT_MEMBER_DOCS       = NO
MARKDOWN_SUPPORT       = YES
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = YES
