@PACKAGE_INIT@

# The optional stream component (doppler::stream*) links Threads::Threads
# (PUBLIC), so resolve it before loading the targets. The core targets need only
# -lm and pull no dependency here.
include(CMakeFindDependencyMacro)
find_dependency(Threads)

include("${CMAKE_CURRENT_LIST_DIR}/doppler-targets.cmake")

# Link targets provided to consumers (all relocatable, generated by the export
# above — no hand-rolled paths):
#
#   doppler::doppler         shared (libdoppler.so) — pure C, links -ldoppler -lm.
#   doppler::doppler-static  the self-contained static archive — pure C, links
#                            with only -lm.
#   doppler::stream[-static] OPTIONAL NATS stream layer (libdoppler_stream,
#                            vendored nats.c folded in); link it only if you
#                            need the dp_pub_*/dp_sub_* wire layer or
#                            wfmgen's `--output nats://`.

check_required_components(doppler)
