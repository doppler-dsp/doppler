      <memberdef kind="function" id="spectral__core_8h_1aeed76dcd1efa7822581c317ca892984c" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>float</type>
        <definition>float kaiser_enbw</definition>
        <argsstring>(const float *w, size_t w_len)</argsstring>
        <name>kaiser_enbw</name>
        <param>
          <type>const float *</type>
          <declname>w</declname>
        </param>
        <param>
          <type>size_t</type>
          <declname>w_len</declname>
        </param>
        <briefdescription>
<para>Equivalent noise bandwidth of window <computeroutput>w</computeroutput>. </para>
        </briefdescription>
        <detaileddescription>
<para>ENBW = N * sum(w^2) / sum(w)^2</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>w</parametername>
</parameternamelist>
<parameterdescription>
<para>Float32 window coefficients, length <computeroutput>w_len</computeroutput>. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>w_len</parametername>
</parameternamelist>
<parameterdescription>
<para>Number of window samples. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>ENBW in bins. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
