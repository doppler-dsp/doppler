      <memberdef kind="function" id="corr__core_8c_1af52b2182a9fe5f2d150ed02cc95fecdd" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>size_t</type>
        <definition>size_t corr_execute</definition>
        <argsstring>(corr_state_t *state, const float complex *in, size_t n_in, float complex *out)</argsstring>
        <name>corr_execute</name>
        <param>
          <type><ref refid="structcorr__state__t" kindref="compound">corr_state_t</ref> *</type>
          <declname>state</declname>
        </param>
        <param>
          <type>const float complex *</type>
          <declname>in</declname>
        </param>
        <param>
          <type>size_t</type>
          <declname>n_in</declname>
        </param>
        <param>
          <type>float complex *</type>
          <declname>out</declname>
        </param>
        <briefdescription>
<para>Correlate one frame and optionally dump the accumulator. </para>
        </briefdescription>
        <detaileddescription>
<para>Steps:<orderedlist>
<listitem><para>FFT(in) → work_fft</para>
</listitem><listitem><para><computeroutput>work_fft[k] *= ref_spec[k]</computeroutput> (frequency-domain multiplication)</para>
</listitem><listitem><para>IFFT(work_fft) → work_ifft (unnormalized; divide by n)</para>
</listitem><listitem><para><computeroutput>accum[k] += work_ifft[k] / n</computeroutput></para>
</listitem><listitem><para>count++</para>
</listitem><listitem><para>If count == dwell: copy accum → out, zero accum, reset count, return n.</para>
</listitem><listitem><para>Otherwise: return 0 (no output this call).</para>
</listitem></orderedlist>
</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>state</parametername>
</parameternamelist>
<parameterdescription>
<para>Must be non-NULL. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>in</parametername>
</parameternamelist>
<parameterdescription>
<para>Input frame of length n_in (must equal state-&gt;n). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>n_in</parametername>
</parameternamelist>
<parameterdescription>
<para>Number of input samples; ignored beyond state-&gt;n. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>out</parametername>
</parameternamelist>
<parameterdescription>
<para>Output buffer of length &gt;= state-&gt;n. Only written when the function returns n (dump). </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>n on a dump, 0 otherwise. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
