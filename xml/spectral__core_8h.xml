      <memberdef kind="function" id="spectral__core_8h_1aaa32dc58066bf93f42f57c3a94b7de54" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void hann_window</definition>
        <argsstring>(float *w, size_t w_len)</argsstring>
        <name>hann_window</name>
        <param>
          <type>float *</type>
          <declname>w</declname>
