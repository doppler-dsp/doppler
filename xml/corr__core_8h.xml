<parameteritem>
<parameternamelist>
<parametername>in</parametername>
</parameternamelist>
<parameterdescription>
<para>Input frame of length n_in (must equal state-&gt;n). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>n_in</parametername>
</parameternamelist>
<parameterdescription>
<para>Number of input samples; ignored beyond state-&gt;n. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>out</parametername>
</parameternamelist>
<parameterdescription>
<para>Output buffer of length &gt;= state-&gt;n. Only written when the function returns n (dump). </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>n on a dump, 0 otherwise. </para>
</simplesect>
</para>
