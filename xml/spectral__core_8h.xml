        <param>
          <type>size_t</type>
          <declname>w_len</declname>
        </param>
        <briefdescription>
<para>Fill <computeroutput>w</computeroutput> with a Hann window. </para>
        </briefdescription>
        <detaileddescription>
<para>w(k) = 0.5 * (1 - cos(2π k / (N-1))), k = 0..N-1.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>w</parametername>
</parameternamelist>
<parameterdescription>
<para>Output buffer, length <computeroutput>w_len</computeroutput> (modified in-place). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>w_len</parametername>
</parameternamelist>
<parameterdescription>
<para>Window length &gt;= 1. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
