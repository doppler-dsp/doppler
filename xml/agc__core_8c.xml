      <memberdef kind="function" id="agc__core_8c_1af4c684ef712280870e95e56c79336918" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void agc_reset</definition>
        <argsstring>(agc_state_t *state)</argsstring>
        <name>agc_reset</name>
        <param>
          <type><ref refid="structagc__state__t" kindref="compound">agc_state_t</ref> *</type>
          <declname>state</declname>
        </param>
        <briefdescription>
<para>Reset the AGC to its post-create state. </para>
        </briefdescription>
        <detaileddescription>
<para>Zeroes <computeroutput>gain_db</computeroutput> and re-seeds <computeroutput>p_avg</computeroutput> from the current <computeroutput>ref_db</computeroutput>. Configuration (<computeroutput>ref_db</computeroutput>, <computeroutput>loop_bw</computeroutput>, <computeroutput>alpha</computeroutput>, <computeroutput>decim</computeroutput>, <computeroutput>clip_db</computeroutput>) is unchanged. <parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>state</parametername>
</parameternamelist>
<parameterdescription>
<para>Must be non-NULL. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="native/src/agc/agc_core.c" line="31" column="1" bodyfile="native/src/agc/agc_core.c" bodystart="31" bodyend="36"/>
