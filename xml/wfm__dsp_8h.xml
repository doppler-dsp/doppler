      </memberdef>
      <memberdef kind="function" id="wfm__dsp_8h_1a5d93a409ecc9d37f4847dd8db11c6c8f" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void wfm_dsss_spread</definition>
        <argsstring>(const float _Complex *syms, size_t n_sym, const uint8_t *code, size_t sf, float _Complex *out)</argsstring>
        <name>wfm_dsss_spread</name>
        <param>
          <type>const float _Complex *</type>
          <declname>syms</declname>
        </param>
        <param>
          <type>size_t</type>
          <declname>n_sym</declname>
        </param>
        <param>
          <type>const uint8_t *</type>
          <declname>code</declname>
        </param>
        <param>
          <type>size_t</type>
          <declname>sf</declname>
        </param>
        <param>
          <type>float _Complex *</type>
          <declname>out</declname>
        </param>
        <briefdescription>
<para>Spread <computeroutput>n_sym</computeroutput> complex data symbols by a binary PN code. </para>
        </briefdescription>
        <detaileddescription>
<para><computeroutput>out[i*sf + j] = syms[i] * (code[j] ? -1 : +1)</computeroutput> — each symbol is repeated across <computeroutput>sf</computeroutput> chips, sign-flipped per code chip. Output length is <computeroutput>n_sym*sf</computeroutput>. Works for BPSK (real syms) and QPSK (complex syms).</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>syms</parametername>
</parameternamelist>
<parameterdescription>
<para>complex data symbols;</para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>n_sym</parametername>
</parameternamelist>
<parameterdescription>
<para>their count. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>code</parametername>
</parameternamelist>
<parameterdescription>
<para>PN chip code (0/1), length <computeroutput>sf</computeroutput>;</para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>sf</parametername>
</parameternamelist>
<parameterdescription>
<para>spreading factor. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>out</parametername>
</parameternamelist>
<parameterdescription>
<para>output chips, length <computeroutput>n_sym * sf</computeroutput>. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
