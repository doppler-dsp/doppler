      <memberdef kind="function" id="spectral__core_8h_1a8a6270a421811a026163bf4578028980" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>size_t</type>
        <definition>size_t find_peaks_f32</definition>
        <argsstring>(const float *db, size_t n, size_t n_peaks, float min_db, dp_peak_t *out)</argsstring>
        <name>find_peaks_f32</name>
        <param>
          <type>const float *</type>
          <declname>db</declname>
        </param>
        <param>
          <type>size_t</type>
          <declname>n</declname>
        </param>
        <param>
          <type>size_t</type>
          <declname>n_peaks</declname>
        </param>
        <param>
          <type>float</type>
          <declname>min_db</declname>
        </param>
        <param>
          <type><ref refid="structdp__peak__t" kindref="compound">dp_peak_t</ref> *</type>
          <declname>out</declname>
        </param>
        <briefdescription>
<para>Find up to <computeroutput>n_peaks</computeroutput> local maxima in a DC-centred F32 dB spectrum. </para>
        </briefdescription>
        <detaileddescription>
<para>Algorithm:<orderedlist>
<listitem><para>Local-max scan: db(k) &gt; db(k-1) &amp;&amp; db(k) &gt;= db(k+1), above min_db.</para>
</listitem><listitem><para>Parabolic interpolation for sub-bin frequency accuracy.</para>
</listitem><listitem><para>Sort descending by amplitude; return top n_peaks.</para>
</listitem></orderedlist>
</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>db</parametername>
</parameternamelist>
<parameterdescription>
<para>F32 dB spectrum, DC-centred, length <computeroutput>n</computeroutput>. Must be &gt;= 3. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>n</parametername>
</parameternamelist>
<parameterdescription>
<para>Number of bins. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>n_peaks</parametername>
</parameternamelist>
<parameterdescription>
<para>Maximum number of peaks to return. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>min_db</parametername>
</parameternamelist>
<parameterdescription>
<para>Amplitude threshold; bins below this are ignored. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>out</parametername>
</parameternamelist>
<parameterdescription>
<para>Caller-allocated output array, length &gt;= <computeroutput>n_peaks</computeroutput>. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>Number of peaks written (&lt;= n_peaks). </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
