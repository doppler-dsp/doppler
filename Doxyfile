@INCLUDE               = ~/mcp-store/configs/Doxyfile.base

PROJECT_NAME           = "doppler"
PROJECT_BRIEF          = "Open-source multi-language cross-platform DSP library"
INPUT                  = native/inc native/src
OUTPUT_DIRECTORY       = docs/doxygen

# pocketfft is vendored; signal_stream.h and pyex_common.h are internal glue.
# _ext.c files are CPython binding boilerplate — no user-facing API.
# clib_common.h "included by" graph exceeds the default 50-node cap once enough
# modules include it — DOT_GRAPH_MAX_NODES raised to 100 in Doxyfile.base.
EXCLUDE_PATTERNS       = */pocketfft* \
                         */signal_stream.h \
                         */pyex_common.h \
                         */clib_common.h \
                         *_ext.c
